<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Indispensable en release : Supabase, Kpay, OneSignal, images réseau.
         (En debug/profile, Flutter l'injecte automatiquement — son absence
         ne se voit donc qu'une fois l'APK release installé.) -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Géolocalisation : tri "à proximité" du marketplace (lib/services/geolocation_service.dart) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <application
        android:label="mygabon"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Deep link de retour Auth (confirmation email, reset mot de
                 passe) : remplace la redirection par défaut vers localhost:3000.
                 Le même schéma doit être ajouté aux Redirect URLs autorisées
                 dans Supabase Dashboard > Authentication > URL Configuration.
                 android:autoVerify ne s'applique qu'aux schémas http/https
                 vérifiés par Digital Asset Links (App Links) ; il n'a aucun
                 effet sur un schéma personnalisé comme "mygabon" — le passer
                 à true ne changerait rien à l'isolation entre apps. La vraie
                 protection contre l'interception de ce lien par une autre
                 app est le flux PKCE de supabase_flutter (par défaut) : le
                 lien ne contient qu'un "code" inutilisable sans le
                 code_verifier resté côté client dans ce même appareil. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="mygabon" android:host="login-callback"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
